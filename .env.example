# === Backend Configuration ===
AI_BACKEND=groq
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# === Cloud API Keys ===
GROQ_API_KEY=your_groq_api_key_here

# === Database ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_interview
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# === Redis ===
REDIS_HOST=localhost
REDIS_PORT=6379

# === STT Settings (local: faster-whisper) ===
STT_MODEL_SIZE=distil-small.en      # tiny | base | small | distil-small.en
STT_COMPUTE_TYPE=int8               # float32 | int8

# === LLM Settings (Cloud: Groq) ===
GROQ_MODEL=llama-3.1-8b-instant     # llama-3.1-8b-instant | llama-3.3-70b-versatile
OLLAMA_MODEL=qwen2.5:14b            # Recommended for 16GB VRAM
OLLAMA_BASE_URL=http://localhost:11434
LLM_GPU_LAYERS=-1                   # -1 = all layers on GPU
LLM_CONTEXT_SIZE=8192
LLM_N_THREADS=6                     # Match your physical CPU cores
LLM_TEMPERATURE=0.5
LLM_MAX_TOKENS=512
MAX_CONCURRENT_LLM_SESSIONS=1

# === TTS Settings (local: Kokoro) ===
TTS_VOICE=af_heart                  # Kokoro voice ID
TTS_SAMPLE_RATE=24000

# === llama-cpp-python Vulkan build (run once) ===
# $env:CMAKE_ARGS="-DGGML_VULKAN=on"
# pip install llama-cpp-python --force-reinstall --no-cache-dir

# === Security ===
CORS_ORIGINS=http://localhost:4200
